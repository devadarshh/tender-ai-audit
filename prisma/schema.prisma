generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

/////////////////////////
// AUTH MODELS (NextAuth)
/////////////////////////

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?

    accounts Account[]
    sessions Session[]
    posts    Post[]

    // ✅ YOUR DOMAIN RELATION
    projects Project[]
}

model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String?
    access_token             String?
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String?
    session_state            String?
    refresh_token_expires_in Int?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

/////////////////////////
// EXISTING SAMPLE MODEL
/////////////////////////

model Post {
    id        Int      @id @default(autoincrement())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    createdBy   User   @relation(fields: [createdById], references: [id])
    createdById String

    @@index([name])
}

/////////////////////////
// YOUR CORE PRODUCT MODELS
/////////////////////////

model Project {
    id        String   @id @default(uuid())
    name      String
    userId    String
    createdAt DateTime @default(now())

    user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    documents Document[]
}

model Document {
    id        String   @id @default(uuid())
    projectId String
    fileUrl   String
    fileName  String
    status    String // uploaded | processing | completed | failed
    createdAt DateTime @default(now())

    project  Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
    analyses Analysis[]
}

model Analysis {
    id         String @id @default(uuid())
    documentId String

    rawJson    Json
    summary    Json
    confidence Float

    createdAt DateTime @default(now())

    document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

    missingItems MissingItem[]
    risks        Risk[]
    completeness Completeness?
    graphMetrics GraphMetric?
}

model MissingItem {
    id         String @id @default(uuid())
    analysisId String

    category    String
    title       String
    description String
    severity    String
    page        Int?

    analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
}

model Risk {
    id         String @id @default(uuid())
    analysisId String

    category    String
    title       String
    description String
    impact      String
    severity    String

    analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
}

model Completeness {
    id         String @id @default(uuid())
    analysisId String @unique

    electrical    Int
    plumbing      Int
    hvac          Int
    structural    Int
    safety        Int
    documentation Int

    analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
}

model GraphMetric {
    id         String @id @default(uuid())
    analysisId String @unique

    riskLow    Int
    riskMedium Int
    riskHigh   Int

    missingElectrical Int
    missingPlumbing   Int
    missingHVAC       Int
    missingStructural Int
    missingSafety     Int
    missingDocs       Int

    analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
}
